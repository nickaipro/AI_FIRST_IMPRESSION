# ====== AI FIRST IMPRESSION - Environment Variables Template ======
# Copia este archivo a .env.local y rellena con tus API keys reales

# ====== REQUERIDAS ======
OPENROUTER_API_KEY=tu_openrouter_api_key_aqui
FIRECRAWL_API_KEY=tu_firecrawl_api_key_aqui

# ====== OPCIONALES - MODELOS ======
# Modelo principal (texto o multimodal básico)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Modelo para análisis visual con screenshots (debe soportar imágenes)
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# ====== OPCIONALES - CACHE Y RATE LIMITING ======
# Upstash Redis (recomendado para producción)
# Sin configurar: funciona sin caché ni rate limiting
# UPSTASH_REDIS_REST_URL=https://tu-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=tu_token_upstash_aqui

# ====== NOTAS ======
# - OPENROUTER_API_KEY: Obtén en https://openrouter.ai/keys
# - FIRECRAWL_API_KEY: Obtén en https://firecrawl.dev
# - Upstash Redis: Crea cuenta gratis en https://upstash.com (10k requests/día)
# - Los modelos por defecto son los óptimos para costo/calidad
